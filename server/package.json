{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "nodemon",
    "db:generate": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0"
  }
}
