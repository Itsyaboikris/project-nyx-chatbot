# Copy to .env and set values. Used by docker-compose and the app.

# Postgres (must match docker-compose POSTGRES_*)
POSTGRES_PASSWORD=changeme
POSTGRES_USER=nyx
POSTGRES_DB=nyx

# Redis
REDIS_PASSWORD=changeme

# App connection strings (server reads these)
DATABASE_URL=postgresql://nyx:changeme@localhost:5432/nyx
REDIS_URL=redis://:changeme@localhost:6379

# Server
PORT=3000
LOG_LEVEL=info

# Local Llama (Ollama) – step 5
OLLAMA_BASE_URL=http://192.168.100.128:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Max input tokens sent to the model (prompt truncated if larger). ~4 chars/token heuristic.
MAX_INPUT_TOKENS=4096
LAST_N_MESSAGES=20
CACHE_TTL_SECONDS=300
RAG_TOP_K=5
MAX_DOCUMENT_SIZE_BYTES=10485760
